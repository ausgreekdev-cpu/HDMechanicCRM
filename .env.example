# HDMechanicCRM Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Secret key for Flask sessions (change this to a random string!)
CRM_SECRET_KEY=change-me-to-a-random-64-char-string

# SMTP Configuration (optional - for email notifications)
CRM_SMTP_SERVER=
CRM_SMTP_PORT=587
CRM_SMTP_USERNAME=
CRM_SMTP_PASSWORD=
CRM_SMTP_FROM=

# Flask Debug Mode (set to 1 for development, 0 for production)
FLASK_DEBUG=0
