# HDMechanicCRM Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
CRM_SECRET_KEY=change-me-to-a-random-64-char-string

# Admin credentials (auto-created on first run)
CRM_ADMIN_USER=admin
CRM_ADMIN_PASSWORD=change-me-to-a-strong-password

# Database (default: SQLite at data/crm.db)
# For PostgreSQL: postgresql://user:pass@localhost:5432/hdmechanic
CRM_DATABASE_URL=

# Flask Debug Mode (set to 1 for development, 0 for production)
FLASK_DEBUG=0

# Server
CRM_PORT=8000
CRM_GUNICORN_WORKERS=4
CRM_GUNICORN_TIMEOUT=120

# Logging
CRM_LOG_LEVEL=INFO
CRM_LOG_FILE=

# SMTP Configuration (optional - for email notifications)
CRM_SMTP_SERVER=
CRM_SMTP_PORT=587
CRM_SMTP_USERNAME=
CRM_SMTP_PASSWORD=
CRM_SMTP_FROM=

# Database Pool (PostgreSQL only)
CRM_DB_POOL_SIZE=10
CRM_DB_MAX_OVERFLOW=20
CRM_DB_POOL_RECYCLE=3600
CRM_DB_ECHO=0

# Reverse Proxy
CRM_FORWARDED_ALLOW_IPS=*
